; Sophia Basic v.1 (2026) by Karel Mozdren
; Phase 4: full 16-bit signed integer expressions + comparisons + AND/OR/NOT.
; Plain-text lines, 100 lines max, 80 columns.
;
; Notes:
; - Integer model: signed 16-bit for numeric variables + expressions.
; - Adds relational operators (=, <>, <, >, <=, >=) and boolean operators AND/OR/NOT.
; - Still plain-text program storage; no tokenization.

.org 0x0400
.include "kernel.s8"
.include "cli.s8"
.include "mem.s8"
.include "fmt.s8"
.include "str.s8"
.include "text.s8"
.include "rng.s8"
.include "basic_helpers.s8"
.include "basic_state.s8"
.include "basic_rng.s8"
.include "basic_init.s8"

; Fixed-address strings + keyword strings extracted to keep the BASIC core
; focused on runtime logic.
.include "basic_strings.s8"
.include "basic_errors.s8"


; ---------------------------------------------------------------------------
; State vars
; ---------------------------------------------------------------------------
; State vars
; ---------------------------------------------------------------------------
; (State extracted to basic_state.s8)

; Entry
; ---------------------------------------------------------------------------
.org 0x0C00
.org

; ---------------------------------------------------------------------------
; REPL + RUN loop extracted to external library: basic_repl.s8
; The entry point marker (.org with no operand) stays here to keep the program
; entry stable and obvious.
; ---------------------------------------------------------------------------
.include "basic_repl.s8"

; ---------------------------------------------------------------------------
; Program line store (same format as v1 patched)
; Program base = 0x3000
; ---------------------------------------------------------------------------
.include "basic_progstore.s8"

; ---------------------------------------------------------------------------
; EXEC_STMT: immediate or program
; ---------------------------------------------------------------------------
; ---------------------------------------------------------------------------
; Statement dispatcher + built-in commands
; [moved to external library: basic_stmt.s8]
; ---------------------------------------------------------------------------

; ---------------------------------------------------------------------------
; Expression engine extracted to basic_expr.s8
; NOTE: included BEFORE basic_stmt.s8 to avoid forward-reference issues.
; ---------------------------------------------------------------------------
.include "basic_vars.s8"
.include "basic_expr.s8"

; PRINT / INPUT plumbing
.include "basic_io.s8"

.include "basic_flow.s8"
.include "basic_assign.s8"
.include "basic_stmt.s8"

; ---------------------------------------------------------------------------
; Variables + expression engine (Phase 3)
; ---------------------------------------------------------------------------
;
; Memory map used by BASIC:
;   Var table:   0x6000..0x63FF (64 entries * 16 bytes)
;   String heap: 0xA000..0xBFFF (simple bump allocator)
;
; Entry layout (16 bytes):
;   0..7   name (zero-padded)
;   8      type (0=int, 1=string, 0xFF=empty)
;   9      reserved
;   10     int_hi
;   11     int_lo
;   12     str_ptr_hi
;   13     str_ptr_lo
;   14     str_len
;   15     reserved

; ---------------------------------------------------------------------------
; COPY_INBUF_6C00_TO_6D00
; Copies NUL-terminated line from 0x6C00 to 0x6D00 (inclusive of terminator).
; This protects the parser from any unexpected modifications to the CLI buffer.
; ---------------------------------------------------------------------------
; [moved to external library: COPY_INBUF_6C00_TO_6D00]

; INIT_VARS extracted to basic_init.s8

; ----------------------
; CURPTR helpers
; ----------------------
; ---------------------------------------------------------------------------
; Expression engine extracted to basic_expr.s8 (included earlier)
; ---------------------------------------------------------------------------

; ---------------------------------------------------------------------------
; RNG extracted to basic_rng.s8 (wrapper) + rng.s8 (core).
; ---------------------------------------------------------------------------

; ---------------------------------------------------------------------------
; Helpers are provided by: text.s8 and basic_helpers.s8
; ---------------------------------------------------------------------------
